@* MediSync.Web/Views/Account/Register.cshtml *@
@model MediSync.Web.ViewModels.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Create Account — MediSync</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" />
    <style>
            * {
                box-sizing: border-box;
                margin: 0;
                padding: 0;
            }

            body {
                font-family: 'Segoe UI', sans-serif;
                height: 100vh;
                overflow: hidden;
                background: #f0f4f8;
            }

            .page-wrapper {
                display: flex;
                height: 100vh;
            }

            /* ── Left Panel ── */
            .left-panel {
                width: 42%;
                background: linear-gradient(160deg, #0d3b6e 0%, #1B4F8A 50%, #1a7a4a 100%);
                display: flex;
                flex-direction: column;
                align-items: center;
                justify-content: center;
                padding: 48px 40px;
                position: relative;
                overflow: hidden;
            }

                .left-panel::before {
                    content: '';
                    position: absolute;
                    width: 350px;
                    height: 350px;
                    border-radius: 50%;
                    border: 1px solid rgba(255,255,255,0.06);
                    top: -100px;
                    right: -100px;
                }

                .left-panel::after {
                    content: '';
                    position: absolute;
                    width: 250px;
                    height: 250px;
                    border-radius: 50%;
                    border: 1px solid rgba(255,255,255,0.06);
                    bottom: -60px;
                    left: -60px;
                }

            .logo-area {
                text-align: center;
                margin-bottom: 40px;
                z-index: 1;
            }

                .logo-area img {
                    width: 180px;
                    margin-bottom: 8px;
                }

            .logo-tagline {
                font-size: 13px;
                color: rgba(255,255,255,0.6);
                letter-spacing: 0.03em;
            }

            .trust-card {
                display: flex;
                align-items: center;
                gap: 14px;
                background: rgba(255,255,255,0.08);
                border: 0.5px solid rgba(255,255,255,0.12);
                border-radius: 12px;
                padding: 14px 18px;
                margin-bottom: 12px;
                width: 100%;
                z-index: 1;
            }

            .trust-icon {
                width: 38px;
                height: 38px;
                background: rgba(255,255,255,0.12);
                border-radius: 10px;
                display: flex;
                align-items: center;
                justify-content: center;
                flex-shrink: 0;
                font-size: 18px;
                color: #fff;
            }

            .trust-title {
                font-size: 13px;
                font-weight: 600;
                color: #fff;
            }

            .trust-sub {
                font-size: 11px;
                color: rgba(255,255,255,0.5);
                margin-top: 2px;
            }

            /* ── Right Panel ── */
            .right-panel {
                flex: 1;
                background: #fff;
                display: flex;
                align-items: center;
                justify-content: center;
                padding: 40px;
                overflow-y: auto;
            }

            .form-wrapper {
                width: 100%;
                max-width: 420px;
            }

            .form-title {
                font-size: 22px;
                font-weight: 600;
                color: #1a202c;
                margin-bottom: 4px;
            }

            .form-subtitle {
                font-size: 13px;
                color: #718096;
                margin-bottom: 28px;
            }

            .form-label {
                font-size: 12px;
                font-weight: 600;
                color: #4a5568;
                margin-bottom: 5px;
                display: block;
            }

            .form-control {
                border: 1px solid #e2e8f0;
                border-radius: 8px;
                padding: 10px 14px;
                font-size: 13px;
                color: #2d3748;
                background: #f7fafc;
                width: 100%;
                transition: border-color 0.15s;
            }

                .form-control:focus {
                    border-color: #1B4F8A;
                    background: #fff;
                    outline: none;
                    box-shadow: 0 0 0 3px rgba(27,79,138,0.1);
                }

            .input-icon-wrapper {
                position: relative;
            }

                .input-icon-wrapper .form-control {
                    padding-right: 38px;
                }

            .input-icon {
                position: absolute;
                right: 12px;
                top: 50%;
                transform: translateY(-50%);
                color: #a0aec0;
                font-size: 16px;
                cursor: pointer;
            }

            /* Role Cards */
            .role-grid {
                display: grid;
                grid-template-columns: repeat(3, 1fr);
                gap: 10px;
                margin-bottom: 20px;
            }

            .role-card {
                border: 1.5px solid #e2e8f0;
                border-radius: 10px;
                padding: 12px 8px;
                text-align: center;
                cursor: pointer;
                transition: all 0.15s;
                background: #f7fafc;
            }

                .role-card:hover {
                    border-color: #1B4F8A;
                    background: #EBF4FF;
                }

                .role-card.active {
                    border-color: #1B4F8A;
                    background: #EBF4FF;
                }

                .role-card i {
                    font-size: 22px;
                    color: #a0aec0;
                    display: block;
                    margin-bottom: 6px;
                }

                .role-card.active i {
                    color: #1B4F8A;
                }

                .role-card span {
                    font-size: 11px;
                    color: #718096;
                    font-weight: 500;
                }

                .role-card.active span {
                    color: #1B4F8A;
                    font-weight: 600;
                }

            /* Password Strength */
            .strength-bar {
                display: flex;
                gap: 4px;
                margin-top: 6px;
            }

            .strength-seg {
                height: 3px;
                flex: 1;
                border-radius: 2px;
                background: #e2e8f0;
                transition: background 0.2s;
            }

            /* Submit Button */
            .btn-register {
                width: 100%;
                padding: 12px;
                background: #1B4F8A;
                color: #fff;
                border: none;
                border-radius: 8px;
                font-size: 14px;
                font-weight: 600;
                cursor: pointer;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
                margin-bottom: 16px;
                transition: background 0.15s;
            }

                .btn-register:hover {
                    background: #15407a;
                }

            .login-link {
                text-align: center;
                font-size: 13px;
                color: #718096;
            }

                .login-link a {
                    color: #1B4F8A;
                    font-weight: 600;
                    text-decoration: none;
                }

            .terms {
                font-size: 11px;
                color: #a0aec0;
                text-align: center;
                margin-bottom: 16px;
            }

                .terms a {
                    color: #1B4F8A;
                }

            .validation-error {
                font-size: 11px;
                color: #E53E3E;
                margin-top: 4px;
            }

            .alert-danger {
                background: #fff5f5;
                border: 1px solid #fed7d7;
                color: #c53030;
                border-radius: 8px;
                padding: 10px 14px;
                font-size: 13px;
                margin-bottom: 16px;
            }

            .success-message {
                background: #f0fff4;
                border: 1px solid #c6f6d5;
                color: #276749;
                border-radius: 8px;
                padding: 10px 14px;
                font-size: 13px;
                margin-bottom: 16px;
            }

            .logo-area img {
                width: 100%;
                height: 100%;
                margin-bottom: -120px;
            }
    </style>
</head>
<body>
    <div class="page-wrapper">

        @* ── Left Panel ── *@
        <div class="left-panel">
            <div class="logo-area">
                @* Replace with your actual logo path *@
                <img src="~/images/medisync.png" alt="MediSync" />
                @* <div class="logo-tagline">Connecting Health Solutions</div> *@
            </div>

            <div class="trust-card">
                <div class="trust-icon"><i class="bi bi-shield-check"></i></div>
                <div>
                    <div class="trust-title">ABDM Compliant</div>
                    <div class="trust-sub">Ayushman Bharat Digital Mission</div>
                </div>
            </div>

            <div class="trust-card">
                <div class="trust-icon"><i class="bi bi-lock-fill"></i></div>
                <div>
                    <div class="trust-title">End-to-End Encrypted</div>
                    <div class="trust-sub">Your health data is always secure</div>
                </div>
            </div>

            <div class="trust-card">
                <div class="trust-icon"><i class="bi bi-people-fill"></i></div>
                <div>
                    <div class="trust-title">500+ Doctors</div>
                    <div class="trust-sub">Across 20+ specialties</div>
                </div>
            </div>
        </div>

        @* ── Right Panel ── *@
        <div class="right-panel">
            <div class="form-wrapper">

                <div class="form-title">Create your account</div>
                <div class="form-subtitle">Join MediSync and take control of your health records</div>

                @* Success message *@
                @if (TempData["SuccessMessage"] != null)
                {
                    <div class="success-message">
                        <i class="bi bi-check-circle-fill"></i> @TempData["SuccessMessage"]
                    </div>
                }

                @* API error message *@
                @if (!ViewData.ModelState.IsValid)
                {
                    <div class="alert-danger">
                        <i class="bi bi-exclamation-circle"></i>
                        @Html.ValidationSummary(true)
                    </div>
                }

                <form asp-action="Register" method="post">
                    @Html.AntiForgeryToken()

                    @* Name Row *@
                    <div class="row g-3 mb-3">
                        <div class="col-6">
                            <label class="form-label">First name</label>
                            <input asp-for="FirstName" class="form-control" placeholder="Sachin" />
                            <span asp-validation-for="FirstName" class="validation-error"></span>
                        </div>
                        <div class="col-6">
                            <label class="form-label">Last name</label>
                            <input asp-for="LastName" class="form-control" placeholder="Mehra" />
                            <span asp-validation-for="LastName" class="validation-error"></span>
                        </div>
                    </div>

                    @* Email *@
                    <div class="mb-3">
                        <label class="form-label">Email address</label>
                        <div class="input-icon-wrapper">
                            <input asp-for="Email" class="form-control" placeholder="sachin@gmail.com" />
                            <i class="bi bi-envelope input-icon"></i>
                        </div>
                        <span asp-validation-for="Email" class="validation-error"></span>
                    </div>

                    @* Password *@
                    <div class="mb-3">
                        <label class="form-label">Password</label>
                        <div class="input-icon-wrapper">
                            <input asp-for="Password" class="form-control"
                                   placeholder="Min 8 characters"
                                   id="passwordInput"
                                   onkeyup="checkStrength(this.value)" />
                            <i class="bi bi-eye input-icon" id="togglePassword"
                               onclick="togglePasswordVisibility()"></i>
                        </div>
                        <div class="strength-bar" id="strengthBar">
                            <div class="strength-seg" id="s1"></div>
                            <div class="strength-seg" id="s2"></div>
                            <div class="strength-seg" id="s3"></div>
                            <div class="strength-seg" id="s4"></div>
                        </div>
                        <span asp-validation-for="Password" class="validation-error"></span>
                    </div>

                    @* Confirm Password *@
                    <div class="mb-3">
                        <label class="form-label">Confirm password</label>
                        <div class="input-icon-wrapper">
                            <input asp-for="ConfirmPassword" class="form-control"
                                   placeholder="Re-enter your password" />
                            <i class="bi bi-eye input-icon"></i>
                        </div>
                        <span asp-validation-for="ConfirmPassword" class="validation-error"></span>
                    </div>

                    @* Role Selector *@
                    <div class="mb-3">
                        <label class="form-label">I am registering as</label>
                        <input type="hidden" asp-for="Role" id="selectedRole" value="Patient" />
                        <div class="role-grid">
                            <div class="role-card active" onclick="selectRole('Patient', this)">
                                <i class="bi bi-person-heart"></i>
                                <span>Patient</span>
                            </div>
                            <div class="role-card" onclick="selectRole('Doctor', this)">
                                <i class="bi bi-hospital"></i>
                                <span>Doctor</span>
                            </div>
                            <div class="role-card" onclick="selectRole('LabTechnician', this)">
                                <i class="bi bi-eyedropper"></i>
                                <span>Lab Tech</span>
                            </div>
                        </div>
                    </div>

                    @* Terms *@
                    <div class="terms">
                        By registering you agree to our
                        <a href="#">Terms of Service</a> and
                        <a href="#">Privacy Policy</a>
                    </div>

                    @* Submit *@
                    <button type="submit" class="btn-register">
                        <i class="bi bi-person-plus-fill"></i>
                        Create Account
                    </button>

                    <div class="login-link">
                        Already have an account?
                        <a asp-controller="Auth" asp-action="Login">Sign in to MediSync</a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
            // // Role card selection
            function selectRole(role, element) {
                let roleGrids = document.querySelectorAll('.role-card');
                roleGrids.forEach(roleGrid => {
                    roleGrid.classList.remove('active');
                });

                element.classList.add('active');
                document.getElementById('selectedRole').value = role;
            }

            // Password strength checker
            function checkStrength(password) {
                const segs = ['s1', 's2', 's3', 's4'];
                const colors = ['#E53E3E', '#F39C12', '#3182CE', '#27AE60'];
                let score = 0;
                if (password.length >= 8) score++;
                if (/[A-Z]/.test(password)) score++;
                if (/[0-9]/.test(password)) score++;
                if (/[^a-zA-Z0-9]/.test(password)) score++;

                segs.forEach((id, i) => {
                    const seg = document.getElementById(id);
                    seg.style.background = i < score ? colors[score - 1] : '#e2e8f0';
                });
            }

            // Toggle password visibility
            function togglePasswordVisibility() {
                const input = document.getElementById('passwordInput');
                const icon = document.getElementById('togglePassword');
                if (input.type === 'password') {
                    input.type = 'text';
                    icon.classList.replace('bi-eye', 'bi-eye-slash');
                } else {
                    input.type = 'password';
                    icon.classList.replace('bi-eye-slash', 'bi-eye');
                }
            }
    </script>
</body>
</html>