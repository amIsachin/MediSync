@model (string Title, string Icon, string Description)

<div class="coming-soon-card">
    <div class="coming-soon-icon"><i class="bi @Model.Icon"></i></div>
    <div class="coming-soon-title">@Model.Title</div>
    <div class="coming-soon-desc">@Model.Description</div>
    <div class="coming-soon-badge">Coming soon</div>
</div>