<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MediSync.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/MediSync.Web.styles.css" asp-append-version="true" />
</head>
<body>
    <div class="app-shell">

        @* ── Sidebar ── *@
        <aside class="sidebar">
            <div class="sidebar-brand">
                <img src="~/images/medisync.png" alt="MediSync" />
                <span>MediSync</span>
            </div>

            <div class="sidebar-scroll">
                @* Role-based menu — only ONE of these renders *@
                @if (User.IsInRole("Doctor"))
                {
                    <partial name="_DoctorSidebarMenu" />
                }
                else if (User.IsInRole("Patient"))
                {
                    <partial name="_PatientSidebarMenu" />
                }
                else if (User.IsInRole("LabTechnician"))
                {
                    <partial name="_LabTechnicianSidebarMenu" />
                }
            </div>

            <div class="sidebar-footer">
                <div class="sidebar-avatar">
                    @GetInitials(User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value,
                                  User.FindFirst(System.Security.Claims.ClaimTypes.Surname)?.Value)
                </div>
                <div class="sidebar-user-info">
                    <div class="sidebar-user-name">
                        @User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value
                        @User.FindFirst(System.Security.Claims.ClaimTypes.Surname)?.Value
                    </div>
                    <div class="sidebar-user-role">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</div>
                </div>
                <form asp-controller="Account" asp-action="Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="logout-btn" title="Logout">
                        <i class="bi bi-box-arrow-right"></i>
                    </button>
                </form>
            </div>
        </aside>

        @* ── Main Area ── *@
        <div class="main-area">
            <header class="topbar">
                <div class="search-box">
                    <i class="bi bi-search"></i>
                    <input type="text" placeholder="Search..." disabled />
                </div>
                <div class="topbar-right">
                    <i class="bi bi-bell icon-btn"></i>
                    <div class="user-chip">
                        <div class="avatar-sm">
                            @GetInitials(User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value,
                                          User.FindFirst(System.Security.Claims.ClaimTypes.Surname)?.Value)
                        </div>
                        <span>@User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value</span>
                        <span class="role-badge">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                    </div>
                </div>
            </header>

            <main class="content">
                @RenderBody()
            </main>
        </div>
    </div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)

@functions {
    string GetInitials(string? firstName, string? lastName)
    {
        var f = string.IsNullOrEmpty(firstName) ? "" : firstName[0].ToString();
        var l = string.IsNullOrEmpty(lastName) ? "" : lastName[0].ToString();
        return (f + l).ToUpper();
    }
}
</body>
</html>
