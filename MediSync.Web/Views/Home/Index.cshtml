
@{
    ViewData["Title"] = "Home Page";
    var firstName = User.FindFirst(System.Security.Claims.ClaimTypes.GivenName)?.Value;
    var role = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
    var email = User.FindFirst(System.Security.Claims.ClaimTypes.Email)?.Value;
}

<div class="page-header">
    <div>
        <h1>Good morning, @firstName 👋</h1>
        <p>@role — @email</p>
    </div>
</div>

<div class="coming-soon-grid">
    @if (role == "Doctor")
    {
        <partial name="_ComingSoonCard" model="@("My Patients", "bi-people", "View and manage your patient list")" />
        <partial name="_ComingSoonCard" model="@("Appointments", "bi-calendar-event", "Today's schedule and upcoming visits")" />
        <partial name="_ComingSoonCard" model="@("Prescriptions", "bi-capsule", "Review and write prescriptions")" />
    }
    else if (role == "Patient")
    {
        <partial name="_ComingSoonCard" model="@("My Records", "bi-file-medical", "View your complete medical history")" />
        <partial name="_ComingSoonCard" model="@("Appointments", "bi-calendar-event", "Book and track your appointments")" />
        <partial name="_ComingSoonCard" model="@("Prescriptions", "bi-capsule", "View your active prescriptions")" />
    }
    else if (role == "LabTechnician")
    {
        <partial name="_ComingSoonCard" model="@("Test Orders", "bi-clipboard2-pulse", "Pending lab test requests")" />
        <partial name="_ComingSoonCard" model="@("Upload Results", "bi-upload", "Submit completed test results")" />
    }
</div>