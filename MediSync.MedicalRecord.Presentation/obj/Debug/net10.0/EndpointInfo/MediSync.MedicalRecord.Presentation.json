  "components": {
    "schemas": {
      "AddAllergyRequest": {
        "required": [
          "substance",
          "severity",
          "doctorId",
          "notes"
        ],
        "type": "object",
        "properties": {
          "substance": {
            "type": "string"
          },
          "severity": {
            "$ref": "#/components/schemas/AllergySeverity"
          },
          "doctorId": {
            "type": "string",
            "format": "uuid"
          },
          "notes": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "AddDiagnosisRequest": {
        "required": [
          "doctorId",
          "icdCode",
          "description"
        ],
        "type": "object",
        "properties": {
          "doctorId": {
            "type": "string",
            "format": "uuid"
          },
          "icdCode": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      },
      "AllergySeverity": {
        "type": "integer"
      },
      "BloodGroup": {
        "type": "integer"
      },
      "CreatePatientProfileRequest": {
        "required": [
          "userId",
          "firstName",
          "lastName",
          "dateOfBirth",
          "bloodGroup",
          "gender",
          "email",
          "phoneNumber"
        ],
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "firstName": {
            "type": "string"
          },
          "lastName": {
            "type": "string"
          },
          "dateOfBirth": {
            "type": "string",
            "format": "date"
          },
          "bloodGroup": {
            "$ref": "#/components/schemas/BloodGroup"
          },
          "gender": {
            "$ref": "#/components/schemas/GenderType"
          },
          "email": {
            "type": "string"
          },
          "phoneNumber": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "EncounterType": {
        "type": "integer"
      },
      "GenderType": {
        "type": "integer"
      },
      "RecordEncounterRequest": {
        "required": [
          "doctorId",
          "encounterType",
          "chiefComplaint",
          "notes",
          "facility"
        ],
        "type": "object",
        "properties": {
          "doctorId": {
            "type": "string",
            "format": "uuid"
          },
          "encounterType": {
            "$ref": "#/components/schemas/EncounterType"
          },
          "chiefComplaint": {
            "type": "string"
          },
          "notes": {
            "type": [
              "null",
              "string"
            ]
          },
          "facility": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      },
      "WeatherForecast": {
        "type": "object",
        "properties": {
          "date": {
            "type": "string",
            "format": "date"
          },
          "temperatureC": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "temperatureF": {
            "pattern": "^-?(?:0|[1-9]\\d*)$",
            "type": [
              "integer",
              "string"
            ],
            "format": "int32"
          },
          "summary": {
            "type": [
              "null",
              "string"
            ]
          }
        }
      }
    }
